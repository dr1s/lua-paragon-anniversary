<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
	<Script file="ParagonExpBar.lua"/>

	<!-- Paragon Experience Bar - Positioned above MainMenuBar -->
	<Frame name="ParagonExpBar" enableMouse="true" parent="MainMenuBar" hidden="true" frameLevel="-1">
		<Size>
			<AbsDimension x="1024" y="11"/>
		</Size>
		<Anchors>
			<!-- By default, positioned above MainMenuBar (same as ReputationWatchBar) -->
			<Anchor point="BOTTOM" relativeTo="MainMenuBar" relativePoint="TOP">
				<Offset>
					<AbsDimension x="0" y="-3"/>
				</Offset>
			</Anchor>
		</Anchors>

		<Frames>
			<StatusBar name="$parentStatusBar" frameLevel="-999" parentKey="StatusBar" minValue="0" maxValue="100" defaultValue="0">
				<Size>
					<AbsDimension x="1024" y="8"/>
				</Size>
				<Anchors>
					<Anchor point="TOP"/>
				</Anchors>

				<Layers>
					<Layer level="OVERLAY">
						<!-- Segment 0: Left part of the decorative frame -->
						<Texture name="$parentTexture0" file="Interface\PaperDollInfoFrame\UI-ReputationWatchBar">
							<Size>
								<AbsDimension x="256" y="11"/>
							</Size>
							<Anchors>
								<Anchor point="TOPLEFT">
									<Offset>
										<AbsDimension x="0" y="2"/>
									</Offset>
								</Anchor>
							</Anchors>
							<TexCoords left="0" right="1.0" top="0" bottom="0.171875"/>
						</Texture>
						<!-- Segment 1: Middle-left part -->
						<Texture name="$parentTexture1" file="Interface\PaperDollInfoFrame\UI-ReputationWatchBar">
							<Size>
								<AbsDimension x="256" y="11"/>
							</Size>
							<Anchors>
								<Anchor point="LEFT" relativeTo="$parentTexture0" relativePoint="RIGHT"/>
							</Anchors>
							<TexCoords left="0" right="1.0" top="0.171875" bottom="0.34375"/>
						</Texture>
						<!-- Segment 2: Middle-right part -->
						<Texture name="$parentTexture2" file="Interface\PaperDollInfoFrame\UI-ReputationWatchBar">
							<Size>
								<AbsDimension x="256" y="11"/>
							</Size>
							<Anchors>
								<Anchor point="LEFT" relativeTo="$parentTexture1" relativePoint="RIGHT"/>
							</Anchors>
							<TexCoords left="0" right="1.0" top="0.34375" bottom="0.515625"/>
						</Texture>
						<!-- Segment 3: Right part -->
						<Texture name="$parentTexture3" file="Interface\PaperDollInfoFrame\UI-ReputationWatchBar">
							<Size>
								<AbsDimension x="256" y="11"/>
							</Size>
							<Anchors>
								<Anchor point="LEFT" relativeTo="$parentTexture2" relativePoint="RIGHT"/>
							</Anchors>
							<TexCoords left="0" right="1.0" top="0.515625" bottom="0.6875"/>
						</Texture>
					</Layer>
				</Layers>

				<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
				<BarColor r="0.90" g="0.80" b="0.50"/>
			</StatusBar>

			<!-- Overlay frame for text -->
			<Frame name="$parentOverlayFrame" frameLevel="999">
				<Anchors>
					<Anchor point="TOPLEFT"/>
					<Anchor point="BOTTOMRIGHT"/>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<FontString name="$parentText" inherits="TextStatusBarText">
							<Anchors>
								<Anchor point="CENTER">
									<Offset>
										<AbsDimension x="0" y="2"/>
									</Offset>
								</Anchor>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
			</Frame>
		</Frames>

		<Scripts>
			<OnLoad>
				self:RegisterEvent("PLAYER_ENTERING_WORLD");
				self:RegisterEvent("PLAYER_LEVEL_UP");
				self:RegisterEvent("UPDATE_FACTION");
				ParagonExpBar_OnLoad(self);
			</OnLoad>
			<OnEvent>
				ParagonExpBar_OnEvent(self, event, ...);
			</OnEvent>
			<OnShow>
				ParagonExpBar_Update();
				UIParent_ManageFramePositions();
			</OnShow>
			<OnHide>
				UIParent_ManageFramePositions();
			</OnHide>
			<OnEnter>
				ParagonExpBarOverlayFrameText:Show();
			</OnEnter>
			<OnLeave>
				ParagonExpBar_SyncTextVisibility();
			</OnLeave>
		</Scripts>
	</Frame>
</Ui>
